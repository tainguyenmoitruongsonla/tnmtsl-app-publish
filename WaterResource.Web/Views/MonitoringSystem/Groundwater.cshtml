@using WaterResource.Service;
@{
    ViewBag.Title = "Giám sát khai thác, sử dụng nước dưới đất";
    UserRightService _service = new UserRightService();
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@if (_service.IsViewAction("/he-thong-giam-sat", User.Identity.Name, "VIEW"))
{
    <link href="~/Assets/leaflet/leaflet.css" rel="stylesheet" />
    <script src="~/Assets/leaflet/leaflet.js"></script>
    <script src="~/Assets/leaflet/L.KML.js"></script>
    <!-- Load Esri Leaflet from CDN -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/esri-leaflet/2.0.4/esri-leaflet.js"></script>

    <!-- Load Esri Leaflet Vector from CDN -->
    <script src="https://unpkg.com/esri-leaflet-vector@3.1.3/dist/esri-leaflet-vector.js" crossorigin=""></script>
    <script src="~/Assets/leaflet/leaflet-bing-layer.js"></script>
    <script src="~/Assets/leaflet/Bing.js"></script>
    <div ng-controller="myCntrl as demo" id="Groundwater">
        <script src="~/Scripts/MonitoringSystem/Controller.js"></script>
        @Html.Partial("ImportServiceJs")

        <!-- Main content -->
        <section class="content p-0">
            <div class="row m-0">
                <!--Bắt đầu bản đồ -->
                <div class="col-md-12 p-0">
                    <div style="width: 100%; height: calc( 60vh - 50px )">
                        <select id="basemaps" class="form-select switch-basemap" aria-label="Default select example">
                            <option value="Imagery">Bản đồ vệ tinh</option>
                            <option value="Topographic">Bản đồ địa hình</option>
                            <option value="Streets">Bản đồ đường</option>
                            <option value="Gray">Bản đồ xám</option>
                        </select>
                        <div class="common-map" id="Map_Groundwater"></div>
                    </div>
                </div>
                <!--Hết bản đồ -->
                <!--phần kiểm soát vận hành các biểu tượng-->
                <div class="col-md-12 p-0">
                    <div class="row m-0 justify-content-center align-items-center pt-2 pb-1 px-2 justify-content-md-between">
                        @Html.Partial("_search")
                    </div>
                    <!--hết Phần các nút chọn-->
                    <!--Phần bảng -->
                    <div class="table-responsive">
                        <table class="table no-margin table-hover table-bordered">
                            <thead class="custom-table-thead">
                                <tr>
                                    <th rowspan="2" class="text-center align-middle text-nowrap">STT</th>
                                    <th rowspan="2" class="text-center align-middle text-nowrap sticky-col start-col">Tên công trình</th>
                                    <th rowspan="2" class="text-center align-middle text-nowrap">Trạng thái vận hành </th>
                                    <th colspan="3" class="text-center align-middle text-nowrap">Lưu lượng khai thác của từng giếng khoan</th>
                                    <th colspan="3" class="text-center align-middle text-nowrap">Mực nước trong giếng khai thác </th>
                                    <th colspan="3" class="text-center align-middle text-nowrap">Mực nước trong giếng quan trắc </th>
                                    <th rowspan="2" class="text-center align-middle text-nowrap sticky-col end-col">Xem chi tiết</th>
                                </tr>
                                <tr>
                                    <th class="text-center align-middle text-nowrap">Yêu cầu</th>
                                    <th class="text-center align-middle text-nowrap">Thực tế</th>
                                    <th class="text-center align-middle text-nowrap">Chênh lệch(+/-)</th>
                                    <th class="text-center align-middle text-nowrap">Yêu cầu</th>
                                    <th class="text-center align-middle text-nowrap">Thực tế</th>
                                    <th class="text-center align-middle text-nowrap">Chênh lệch(+/-)</th>
                                    <th class="text-center align-middle text-nowrap">Yêu cầu</th>
                                    <th class="text-center align-middle text-nowrap">Thực tế</th>
                                    <th class="text-center align-middle text-nowrap">Chênh lệch(+/-)</th>
                                </tr>
                            </thead>
                            <tbody class="custom-table-tbody">
                                <tr ng-repeat="item in DataConstruction">
                                    <th class="text-center align-middle" ng-bind="(currentPage -1)*numPerPage+$index+1"> </th>
                                    <td class="text-nowrap sticky-col start-col" style="min-width:100px">
                                        <span ng-bind-html="item.ConstructionName" class="text-primary" ng-click="zoomConstruction(item.Lng, item.Lat, item.Id)"></span>
                                        <img class="grid-item-image" style="width: 15px;" src="~/LocalFiles/images/earth.png" alt="altImg">
                                    </td>
                                    <td class="text-center align-middle" ng-bind-html="displayOperatingStatus(item)"></td>
                                    <td ng-bind-html="checkValuePreData(item.MiningMaxFlow)"></td>
                                    <td ng-bind-html="checkValuePreData(item.Khaithac)"></td>
                                    <td ng-bind-html="calculatePreData(item.Khaithac, item.MiningMaxFlow)"></td>

                                    <td ng-bind-html="checkValuePreData(item.WellWL)"></td>
                                    <td ng-bind-html="checkValuePreData(item.Giengkhaithac)"></td>
                                    <td ng-bind-html="calculatePreData(item.Giengkhaithac, item.WellWL)"></td>

                                    <td ng-bind-html="checkValuePreData(item.MonitoringWellWL)"></td>
                                    <td ng-bind-html="checkValuePreData(item.Giengquantrac)"></td>
                                    <td ng-bind-html="calculatePreData(item.Giengquantrac, item.MonitoringWellWL)"></td>

                                    <td class="sticky-col end-col">
                                        <div class="d-flex">
                                            <div ng-if="item.ConstructionItems && item.ConstructionItems.length == 1">
                                                <a href="javascript:void(0)" class="px-2 text-nowrap cons-item-button"
                                                   ng-repeat="constructionItem in item.ConstructionItems"
                                                   ng-click="openAside('Groundwater_Operate_Monitoring', 8, item, 'operate_Groundwater', constructionItem)">
                                                    {{constructionItem.Name}}
                                                </a>
                                            </div>
                                            <div ng-if="item.ConstructionItems && item.ConstructionItems.length > 1">
                                                <a href="javascript:void(0)" class="px-2 py-1 text-nowrap btn-success" title="Xem chi tiết"
                                                   ng-click="openAside('Groundwater_Operate_Monitoring', 8, item, 'operate_Groundwater', '')">
                                                    CHI TIẾT
                                                </a>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="floating-label col-md-4 p-0 mx-1">
                        <i class="font-16 font-weight-bold text-danger">(*): Các thông số giám sát theo thông tư 17/2021/TT-BTNMT</i>
                    </div>
                    <!-- pagination phân trang -->
                    <div class="box-footer ">
                        <div class="box-tools pull-right">
                            <ul uib-pagination
                                total-items="TotalCons"
                                ng-model="currentPage"
                                items-per-page="numPerPage"
                                boundary-links="true"
                                previous-text=" &#xf104; " next-text=" &#xf105; "
                                first-text=" &#xf100; " last-text=" &#xf101; "
                                max-size="5" ng-change="pageChanged()"
                                rotate="true"
                                force-ellipses="true" class="pagination pagination-sm d-flex fa my-3"></ul>
                        </div>
                    </div>
                </div>
                <div id="Groundwater_Operate_Monitoring" class="sidenav p-0 ">
                    <div>
                        <div class="doc-title p-2 col-12 d-flex align-items-center" style="background:#15538f; color: #fff; height: 50px">
                            <div class="d-flex col-12 p-0 align-items-center">
                                <div class="col-10 p-0">
                                    <div class="admission-title d-flex center-center">
                                        <p class="m-0 col-12 p-0 text-left text-uppercase font-16"> SỐ LIỆU VẬN HÀNH CỦA CÔNG TRÌNH - {{ConsName}} </p>
                                    </div>
                                </div>
                                <a href="javascript:void(0)" class="closebtn m-0 p-0 text-white" ng-click="closeAside('Groundwater_Operate_Monitoring')"><i class="fa fa-arrow-right font-20"></i></a>
                            </div>
                        </div>
                    </div>
                    <div class="row m-0">
                        <!-- GIAM SAT KET NOI -->
                        <div class="col-md-12 py-2">
                            <div class="card-header rounded-0 p-0">
                                
                                <ul class="nav nav-tabs" id="Irrigation_Operate-tab" role="tablist">
                                    <li class="nav-item">
                                        <a class="nav-link rounded-0 active" id="Groundwater_Operate_Monitoring_Data-tab" data-toggle="pill" href="#Groundwater_Operate_Monitoring_Data" role="tab" aria-controls="Groundwater_Operate_Monitoring_Data" aria-selected="false">Số liệu vận hành</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link rounded-0" id="Groundwater_Operate_Monitoring_Chart-tab" data-toggle="pill" href="#Groundwater_Operate_Monitoring_Chart" role="tab" aria-controls="Groundwater_Operate_Monitoring_Chart" aria-selected="false">Đồ thị vận hành</a>
                                    </li>
                                </ul>
                                <div class="tab-content">
                                    <div class="tab-pane active" id="Groundwater_Operate_Monitoring_Data">
                                        <div class="row m-0 justify-content-end align-items-center py-2">
                                            <div class="row m-0 ">
                                                <div ng-if="con && con.ConstructionItems && con.ConstructionItems.length > 1" class="row m-0 align-items-center">
                                                    <div class="col-auto py-3 mr-2"><label class="m-0">Hạng mục:</label></div>
                                                    <div class="col p-0">
                                                        <select class="form-control form-control-sm" ng-model="SelectedConstructionItemId" ng-change="onSelectConstructionItem(SelectedConstructionItemId)">
                                                            <option value="">-- Chọn hạng mục --</option>
                                                            <option ng-repeat="ci in con.ConstructionItems" value="{{ci.Id}}">{{ci.Name}}</option>
                                                        </select>
                                                    </div>
                                                </div>
                                                <div class="row m-0 align-items-center">
                                                    <span class="px-2">Thời gian từ: </span>
                                                    <div class="row m-0">
                                                        <input type="datetime-local" class="form-control form-control-sm col-md-12" ng-model="inputStartTime" id="inputStartTime">
                                                    </div>
                                                    <span class="px-2">Đến: </span>
                                                    <div class="row m-0">
                                                        <input type="datetime-local" class="form-control form-control-sm col-md-12" ng-model="inputEndTime" id="inputEndTime">
                                                    </div>
                                                </div>
                                                <div class="row m-0 align-items-center p-1">
                                                    <button ng-click="filterPreData('operate_Groundwater')" class="btn btn-sm btn-addnew px-4 mx-2">Áp dụng</button>
                                                    <button class="btn btn-sm btn-addnew px-4 mx-2" data-toggle="modal" data-target="#manualDataEntry"><i class="fa-solid fa-desktop"></i> Nhập thủ công </button>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="card-body p-0">
                                            <!-- Total rows table: shown by default if totals exist and no item selected -->
                                            <div ng-if="HasTotalData && !SelectedConstructionItemId" class="p-2">
                                                <h6 class="mb-2">Bảng tổng lưu lượng</h6>
                                                <div class="table-responsive">
                                                    <table class="table table-sm table-hover table-bordered">
                                                        <thead class="custom-table-thead">
                                                            <tr>
                                                                <th class="text-center align-middle text-nowrap">Thời gian</th>
                                                                <th class="text-center align-middle text-nowrap">Tổng lưu lượng</th>
                                                                <th class="text-center align-middle text-nowrap">Đơn vị</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            <tr ng-repeat="t in TotalRows">
                                                                <td class="text-center align-middle text-nowrap"><span ng-bind="t.Time | date:'dd/MM/yyyy HH:mm'"></span></td>
                                                                <td class="text-center align-middle text-nowrap" ng-bind-html="checkValuePreData(t.tongluuluong)"></td>
                                                                <td class="text-center align-middle text-nowrap" ng-bind="t.Unit"></td>
                                                            </tr>
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>
                                            <div class="table-responsive" ng-if="!HasTotalData || SelectedConstructionItemId">
                                                <table class="table no-margin table-hover table-bordered">
                                                    <thead class="custom-table-thead">
                                                        <tr>
                                                            <th rowspan="2" class="text-center align-middle text-nowrap">STT</th>
                                                            <th rowspan="2" class="text-center align-middle text-nowrap">Thời gian</th>
                                                            <th colspan="2" class="text-center align-middle">Lưu lượng khai thác của từng giếng khoan</th>
                                                            <th colspan="2" class="text-center align-middle">Mực nước trong giếng khai thác </th>
                                                            <th colspan="2" class="text-center align-middle">Mực nước trong giếng quan trắc </th>
                                                            <th rowspan="2" class="text-center align-middle text-nowrap">Trạng thái vận hành </th>
                                                        </tr>
                                                        <tr>
                                                            <th class="text-center align-middle text-nowrap">Yêu cầu</th>
                                                            <th class="text-center align-middle text-nowrap">Thực tế</th>
                                                            <th class="text-center align-middle text-nowrap">Yêu cầu</th>
                                                            <th class="text-center align-middle text-nowrap">Thực tế</th>
                                                            <th class="text-center align-middle text-nowrap">Yêu cầu</th>
                                                            <th class="text-center align-middle text-nowrap">Thực tế</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody class="custom-table-tbody">
                                                        <tr ng-repeat="item in (DataPreForDisplay.length ? DataPreForDisplay : DataPre)">
                                                            <th class="text-center align-middle" ng-bind="(currentPage -1)*numPerPage+$index+1"> </th>
                                                            <td class="text-nowrap"><span ng-bind="item.Time | date:'dd/MM/yyyy HH:mm'"></span> <span ng-bind="item.StationCode"></span></td>
                                                            <td class="text-center align-middle" ng-bind-html="item.ConstructionCode === 'NDDCTTAKIIVN_TK04' || item.ConstructionCode === 'NDDCTTAKIIVN_TK03' || item.ConstructionCode === 'NDDCTTAKIIVN_TK02' || item.ConstructionCode === 'NDDCTTAKIIVN_TK01' ? '-' : checkValuePreData(item.qkhaithacyeucau)"></td>
                                                            <td class="text-center align-middle" ng-bind-html="checkValuePreData(item.khaithac)"></td>

                                                            <td class="text-center align-middle" ng-bind-html="item.ConstructionCode === 'NDDCTTAKIIVN_TK04' || item.ConstructionCode === 'NDDCTTAKIIVN_TK03' || item.ConstructionCode === 'NDDCTTAKIIVN_TK02' || item.ConstructionCode === 'NDDCTTAKIIVN_TK01' ? '-' : checkValuePreData(item.mucnuocyeucau)"></td>
                                                            <td class="text-center align-middle" ng-bind-html="checkValuePreData(item.giengkhaithac)"></td>
                                                            
                                                            <td class="text-center align-middle" ng-bind-html="item.ConstructionCode === 'NDDCTTAKIIVN_TK04' || item.ConstructionCode === 'NDDCTTAKIIVN_TK03' || item.ConstructionCode === 'NDDCTTAKIIVN_TK02' || item.ConstructionCode === 'NDDCTTAKIIVN_TK01' ? '-' : checkValuePreData(item.mucnuocgieng)"></td>
                                                            <td class="text-center align-middle" ng-bind-html="checkValuePreData(item.giengquantrac) ? checkValuePreData(item.giengquantrac) : '-' "></td>
                                                            

                                                            <td ng-bind-html="checkDeviceStatus(item.trangthaithietbi)"></td>
                                                        </tr>
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="tab-pane" id="Groundwater_Operate_Monitoring_Chart">
                                        <div class="col-12 p-0">
                                            <div class="row m-0 justify-content-end align-items-center py-2">
                                                <div class="row m-0 ">
                                                    <div ng-if="con && con.ConstructionItems && con.ConstructionItems.length > 1" class="row m-0 align-items-center">
                                                        <div class="col-auto py-3 mr-2"><label class="m-0">Hạng mục:</label></div>
                                                        <div class="col p-0">
                                                            <select class="form-control form-control-sm" ng-model="SelectedConstructionItemId" ng-change="onSelectConstructionItem(SelectedConstructionItemId)">
                                                                <option value="">-- Chọn hạng mục --</option>
                                                                <option ng-repeat="ci in con.ConstructionItems" value="{{ci.Id}}">{{ci.Name}}</option>
                                                            </select>
                                                        </div>
                                                    </div>
                                                    <div class="row m-0 align-items-center">
                                                        <span class="px-2">Thời gian từ: </span>
                                                        <div class="row m-0">
                                                            <input type="datetime-local" class="form-control form-control-sm col-md-12" ng-model="inputStartTime" id="inputStartTime">
                                                        </div>
                                                        <span class="px-2">Đến: </span>
                                                        <div class="row m-0">
                                                            <input type="datetime-local" class="form-control form-control-sm col-md-12" ng-model="inputEndTime" id="inputEndTime">
                                                        </div>
                                                    </div>
                                                    <div class="row m-0 align-items-center p-1">
                                                        <button ng-click="filterPreData('operate_Groundwater')" class="btn btn-sm btn-addnew px-4 mx-2">Áp dụng</button>
                                                    </div>
                                                </div>
                                            </div>
                                            <div id="operate_Groundwater"></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- /primary modal -->
                <!-- Modal Manual Data -->
        <div class="modal fade" id="manualDataEntry" tabindex="-1" role="dialog" aria-labelledby="manualDataEntryLabel" aria-hidden="true" data-keyboard="false" data-backdrop="static">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="manualDataEntryLabel">Nhập số liệu vận hành</h5>
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        <form>
                            <!-- Tên công trình -->
                            <div class="mb-3">
                                <label for="tenCongTrinh" class="form-label">Tên công trình</label>
                                <input type="text" class="form-control" id="tenCongTrinh" value="{{ConsName}}" readonly>
                                <input type="hidden" class="form-control" id="maCongTrinh" ng-model="storePreDataNDD.ConstructionCode">
                            </div>

                            <!-- Thời gian nhập dữ liệu -->
                            <div class="mb-4">
                                <label for="thoiGian" class="form-label">Thời gian nhập dữ liệu</label>
                                <input type="datetime-local" class="form-control" id="thoiGian" ng-model="storePreDataNDD.Time" required aria-required="true">
                                <div class="invalid-feedback d-block" ng-if="!storePreDataNDD.Time">Vui lòng nhập thời gian trước khi lưu.</div>
                            </div>

                            <!-- 11 hàng dữ liệu -->
                            <div class="row mb-2 fw-bold">
                                <div class="col-md-4">Yếu tố quan trắc</div>
                                <div class="col-md-4"></div>
                                <div class="col-md-2">Giá trị</div>
                                <div class="col-md-2">Đơn vị</div>
                            </div>

                            <!-- Loop 11 yếu tố -->
                            <div id="rowsContainer">
                                <!-- If construction has multiple items, render inputs per item -->
                                <div ng-if="con && con.ConstructionItems && con.ConstructionItems.length > 1">
                                    <div class="row mb-2 p-2 border bg-light align-items-center">
                                        <div class="col-md-8 d-flex align-items-center">
                                            <label class="m-0 font-weight-bold">Tổng lưu lượng khai thác (của tất cả giếng)</label>
                                        </div>
                                        <div class="col-md-3">
                                            <input type="number" step="0.01" class="form-control form-control-sm text-left font-weight-bold" ng-model="storePreDataNDD.Data.TONGLUULUONG" ng-change="onTotalInput()" placeholder="(Nhập tổng nếu chỉ quan trắc tổng)">
                                            <small class="form-text text-muted">Nếu để trống, tổng sẽ tự tính từ tổng lưu lượng từng giếng.</small>
                                        </div>
                                         <div class="col-md-1 d-flex align-items-center"> <span>(m<sup>3</sup>/s)</span>
                                        </div>
                                    </div>

                                    <div ng-repeat="ci in con.ConstructionItems" class="border p-2 mb-2">
                                        <div class="row mb-2 fw-bold">
                                            <div class="col-12">Hạng mục: <strong ng-bind="ci.Name"></strong></div>
                                        </div>

                                        <div class="row mb-2">
                                            <div class="col-md-4"><input type="text" class="form-control" value="Lưu lượng khai thác giếng {{ci.Name}}" readonly></div>
                                            <div class="col-md-4"><input type="text" class="form-control" value="KHAITHAC" readonly></div>
                                            <div class="col-md-2"><input type="number" class="form-control" placeholder="Nhập giá trị" ng-model="storePreDataNDD.Data['KHAITHAC_' + ci.Id]" ng-change="onKhaiThacChanged()"></div>
                                            <div class="col-md-2 d-flex align-items-center"><span>(m<sup>3</sup>/s)</span></div>
                                        </div>

                                        <div class="row mb-2">
                                            <div class="col-md-4"><input type="text" class="form-control" value="GIENGKHAITHAC" readonly></div>
                                            <div class="col-md-4"><input type="text" class="form-control" value="MUCNUOC" readonly></div>
                                            <div class="col-md-2"><input type="number" class="form-control" placeholder="Nhập giá trị" ng-model="storePreDataNDD.Data['GIENGKHAITHAC_' + ci.Id]"></div>
                                            <div class="col-md-2 d-flex align-items-center"><span>(m)</span></div>
                                        </div>

                                        <div class="row mb-2">
                                            <div class="col-md-4"><input type="text" class="form-control" value="GIENGQUANTRAC" readonly></div>
                                            <div class="col-md-4"><input type="text" class="form-control" value="MUCNUOC" readonly></div>
                                            <div class="col-md-2"><input type="number" class="form-control" placeholder="Nhập giá trị" ng-model="storePreDataNDD.Data['GIENGQUANTRAC_' + ci.Id]"></div>
                                            <div class="col-md-2 d-flex align-items-center"><span>(m)</span></div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Default single-item layout -->
                                <div ng-if="!con || !con.ConstructionItems || con.ConstructionItems.length <= 1">

                                    <div class="row mb-2">
                                        <div class="col-md-4"><input type="text" class="form-control" value="Lưu lượng khai thác giếng {{storePreDataNDD.ConsItemName}}" readonly></div>
                                        <div class="col-md-4"><input type="text" class="form-control" value="KHAITHAC" readonly></div>
                                        <div class="col-md-2"><input type="number" class="form-control" placeholder="Nhập giá trị" ng-model="storePreDataNDD.Data.KHAITHAC" required></div>
                                        <div class="col-md-2 d-flex align-items-center"><span>(m<sup>3</sup>/s)</span></div>
                                    </div>

                                    <div class="row mb-2">
                                        <div class="col-md-4"><input type="text" class="form-control" value="GIENGKHAITHAC" readonly></div>
                                        <div class="col-md-4"><input type="text" class="form-control" value="MUCNUOC" readonly></div>
